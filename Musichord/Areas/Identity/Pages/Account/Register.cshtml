@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<h1>@ViewData["Title"]</h1>

<div class="container">
    <div class="row">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div class="col">
                <section>
                    <h3>Connect Your Spotify Account!</h3>
                    <hr />
                    <div class="form-floating mb-3">
                        <input asp-for="Input.SpotEmail" class="form-control spotify-email" autocomplete="spot email" aria-required="true" placeholder="Spotify Email" />
                        <label asp-for="Input.SpotEmail">Spotify Email</label>
                        <span asp-validation-for="Input.SpotEmail" class="text-danger"></span>
                    </div>
                    <div class="form-floating mb-3">
                        <input asp-for="Input.SpotUser" class="form-control spotify-user" autocomplete="spot username" aria-required="true" placeholder="Spotify Username" />
                        <label asp-for="Input.SpotUser">Spotify Username</label>
                        <span asp-validation-for="Input.SpotUser" class="text-danger"></span>
                    </div>
                    <button id="spotifyAdd" type="button" class="w-100 btn btn-lg btn-primary">Add Spotify</button>
                </section>
            </div>
            <div class="col mt-4">
                <h2>Create a new account.</h2>
                <hr />
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Handle" class="form-control" autocomplete="handle" aria-required="true" placeholder="Handle" />
                    <label asp-for="Input.Handle">Handle</label>
                    <span asp-validation-for="Input.Handle" class="text-danger"></span>
                </div>
                <input asp-for="Input.SpotifyToken" hidden class="form-control spotify-token" autocomplete="spot-token" aria-required="true"/>
                <input asp-for="Input.ProfilePicture" hidden class="form-control profile-picture" autocomplete="profile-pic" aria-required="false"/>
                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>     
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script defer type="module" src="~/js/musichordRegister.js"></script>
}
