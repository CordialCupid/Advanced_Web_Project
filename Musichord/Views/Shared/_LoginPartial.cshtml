@using Microsoft.AspNetCore.Identity
@using Musichord.Models.Entities

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    
    var currentUser = await UserManager.GetUserAsync(User);
    
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-light" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            Hello @currentUser?.Handle!
        </a>
        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
            <li>
                <a id="manage" class="dropdown-item dropdown-item-musichord-green" asp-controller="Profile" asp-action="Index" title="Manage">My Profile</a>
            </li>
            <li>
                <a id="manage" class="dropdown-item dropdown-item-musichord-green" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Manage Account</a>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" style="display:inline;">
                    <button id="logout" type="submit" class="dropdown-item dropdown-item-musichord-green">Logout</button>
                </form>
            </li>
        </ul>
    </li>
}

else
{
    <li class="nav-item">
        <a class="nav-link text-light" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-light" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>


