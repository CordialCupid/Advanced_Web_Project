@using Musichord.Models.Entities
@model IEnumerable<string?>


@{
    ViewData["Title"] = "Home Page";
}

<div class="container">
    <div class="row">
        <h1 class="text-primary text-center">Welcome!</h1>
        <p class="lead text-muted" style="text-decoration: underline">Here are people!</p>
    </div>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                Name
            </th>
            <th>
                Add Friend
            </th>
        </tr>
    </thead>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user</td>
            <td><button id="addFriendBtn" type="button" class="btn-primary" data-user-name="@user">Send Friend Request</button></td>     
        </tr>
    }
</table>


@section Scripts{
    <script defer type="module" src="~/js/musichordIndex.js"></script>
} 
