@using Musichord.Models.Entities
@* @model IEnumerable<Friendship> *@


@{
    ViewData["Title"] = "musichord";
}

  <div class="px-4 py-5 my-5 text-center">
    <img class="d-block mx-auto mb-4" src="~/assets/musichordlogo.svg" alt="" width="200" height="57">
    <h1 class="display-5 fw-bold">Welcome to <i>musichord</i></h1>
    <div class="col-lg-6 mx-auto">
      <p class="lead mb-4">Keep track of your friends, learning more about your listening habits, and more.</p>
      @if (ViewData["LoggedIn"] as bool? == false)
      {
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">

            <a href="/Identity/Account/Register" class="btn btn-musichord-green btn-lg px-4 gap-3">Sign Up</a>
            <a href="/Identity/Account/Login" class="btn btn-outline-secondary btn-lg px-4">Log In</a>
        </div>
      } else {
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a href="/Home/Explore" class="btn btn-musichord-green btn-lg px-4 gap-3">Explore</a>
            <a href="/Home/Friends" class="btn btn-outline-secondary btn-lg px-4">Friends</a>
        </div>
      }

    </div>
  </div>

  @{
    var albums = ViewData["RandomAlbums"] as ICollection<Musichord.Models.Entities.Album>;
}

<div class="container">
    <div class="row">
        <h1 class="fw-bold text text-center">Album Spotlight</h1>
        <p class="text text-center">See what other users on <i>musichord</i> are listening to:</p>
    </div>
    <div class="row row-cols-5 g-2">
        @foreach (var album in albums ?? Enumerable.Empty<Musichord.Models.Entities.Album>())
        {
            <div class="col">
                <img src="@album.ImageUrl"
                     alt="@album.Name"
                     class="img-fluid rounded"
                     title="@album.Name" />
            </div>
        }
    </div>
</div>

@section Scripts{
    <script defer type="module" src="~/js/musichordIndex.js"></script>
} 
