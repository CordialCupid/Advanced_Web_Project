@using Musichord.Models.Entities
@model IEnumerable<Friendship>


@{
    ViewData["Title"] = "Home Page";
}

  <div class="px-4 py-5 my-5 text-center">
    <img class="d-block mx-auto mb-4" src="~/assets/musichordlogo.svg" alt="" width="200" height="57">
    <h1 class="display-5 fw-bold">Welcome to <i>musichord</i></h1>
    <div class="col-lg-6 mx-auto">
      <p class="lead mb-4">Keep track of your friends, learning more about your listening habits, and more.</p>
      <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
        <button type="button" class="btn btn-musichord-green btn-lg px-4 gap-3">Sign Up</button>
        <button type="button" class="btn btn-outline-secondary btn-lg px-4">Log In</button>
      </div>
    </div>
  </div>

@section Scripts{
    <script defer type="module" src="~/js/musichordIndex.js"></script>
} 
