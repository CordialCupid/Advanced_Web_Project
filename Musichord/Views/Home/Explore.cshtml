@using Musichord.Models.Entities


@{
    ViewData["Title"] = "Explore";
}

<div class="container mt-2">
    <div class="row">
        <h1 class="fw-bold">Explore</h1>
        <p style="color: #1DB954">Dicover others on Musichord and make friends!</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="userContainer">
            <!-- Additional user cards will be dynamically generated here via Ajax -->
    </div>


    <div class="row" id="emptyState" style="display: none;">
        <div class="col text-center py-5">
            <div class="text-muted">
                <i class="bi bi-person-dash-fill" style="font-size: 4rem;"></i>
                <h4 class="mt-3">Uh Oh! It looks like we don't have any users....</h4>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <h1 class="fw-bold">Activity Feed</h1>
        <p style="color: #1DB954">Here is the activity feed for people you aren't friends with (yet):</p>
    </div>


    <table class="table activity-table">
        <thead>
            <tr>
                <th>
                    User 
                </th>
                <th>
                    Listened To
                </th>
            </tr>
        </thead>
        <!-- Activity feed will be dynamically generated via JavaScript and AJAX-->
        <tbody class="activity-body">

        </tbody>
    </table>

    <div class="row mt-5" id="emptyStateAct" style="display: none;">
        <div class="col text-center py-5">
            <div class="text-muted">
                <h4 class="mt-3">It doesn't look like theres any activity here...</h4>
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script defer type="module" src="~/js/Explore/musichordExplore.js"></script>
} 

<style>
    .add-btn:hover {
        background-color: #1DB954;
    }
</style>