@using Musichord.Models.Entities
@model IEnumerable<string?>


@{
    ViewData["Title"] = "Explore";
}


<div class="input-group">
    <span class="input-group-text clickable-hand" id="basic-addon1">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"></path>
        </svg>
    </span>
    <input type="text" class="form-control" placeholder="Enter User Handle..." aria-label="User Handle Input" aria-describedby="user handle input">
</div>

<table class="table">
    <thead>
        <tr>
            <th>
                Name
            </th>
            <th>
                Details
            </th>
            <th>
                Add
            </th>
        </tr>
    </thead>
    @foreach (var user in Model)
    {
        <tr>
            <td>@user</td>
            <td><button id="viewFriendBtn" type="button" class="btn-primary" data-user-name="@user">View Profile</button></td>  
            <td><button id="addFriendBtn" type="button" class="btn-primary" data-user-handle="@user">Add Friend</button></td>   
        </tr>
    }
</table>

@section Scripts{
    <script defer type="module" src="~/js/musichordExplore.js"></script>
} 