@model IEnumerable<Musichord.Models.Entities.Track>


@{
    ViewData["Title"] = "Profile";
    var isOwnProfile = ViewData["IsOwnProfile"] as bool? ?? false;
}

<div class="container">
    <div class="row">
        <h1 class="text-primary text-center">@ViewData["Handle"]'s Profile</h1>
        @if (isOwnProfile)
        {
            <p class="lead text-muted" style="text-decoration: underline">Here are your top 5 Spotify songs:</p>
        }
        else
        {
            <p class="lead text-muted" style="text-decoration: underline">Here are @ViewData["Handle"]'s favorite songs:</p>
        }
    </div>
</div>

@if (isOwnProfile)
{
    <button id="refreshFive">Refresh Top Five</button>
}

<table class="table">
    <thead>
        <tr>
            <th>
                Name
            </th>
            <th></th>
        </tr>
    </thead>
    @foreach (var track in Model)
    {
        <tr>
            <td>@track.Name</td>
            <td>
            </td>
        </tr>
    }
</table>


@section Scripts{
    <script defer type="module" src="~/js/musichordIndex.js"></script>
} 
